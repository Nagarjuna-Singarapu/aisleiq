# Application
APP_NAME=aisleiq
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
LOG_LEVEL=INFO

# Database
DATABASE_URL=sqlite:///./data/db/store_intelligence.db

# Video Processing
VIDEO_DIR=data/videos
FRAMES_DIR=data/frames
EXPORT_DIR=data/exports
FRAME_SKIP=3
DETECTION_CONFIDENCE=0.4
MAX_TRACK_AGE=30
MIN_HITS=3

# Model
YOLO_MODEL=yolov8n.pt
USE_GPU=false
DEVICE=cpu

# Zones (comma-separated: name:x1,y1,x2,y2 — pixel coords normalized 0-1)
# Example zone definitions for a typical store layout
ZONES=entrance:0.0,0.0,0.25,1.0|checkout:0.75,0.0,1.0,1.0|main_floor:0.25,0.0,0.75,1.0

# Analytics
CROWD_THRESHOLD=10
LOITERING_SECONDS=120
QUEUE_ZONE=checkout
QUEUE_THRESHOLD=3
PEAK_WINDOW_MINUTES=15

# Dashboard
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8501
API_BASE_URL=http://localhost:8000

# CORS
CORS_ORIGINS=http://localhost:8501,http://localhost:3000
